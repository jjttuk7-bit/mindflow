{
  "functions": {
    "app/api/ai/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/insights/preview/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/monthly-insight",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/weekly-insight",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/weekly-nudge",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/morning-push",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/expiry-check",
      "schedule": "0 23 * * *"
    }
  ]
}
